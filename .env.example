# Ethereum RPC URL (Sepolia)
RPC_URL=

# Test account private key (do NOT use mainnet funds)
PRIVATE_KEY=

# Deployed contract address on Sepolia
CONTRACT_ADDRESS=

# Shared ABI path for the whole suite
CONTRACT_ABI_PATH=./shared/contracts/DemoABI.json

# Wait time for transaction confirmation
TX_TIMEOUT_SECONDS=120

# Optional secret used by confidentiality demos in signature-based packs
CONFIDENTIALITY_SECRET=demo_secret

# Optional: enable real IPFS storage for PQC proofs
# Example: /ip4/127.0.0.1/tcp/5001/http
IPFS_API_URL=
